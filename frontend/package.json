{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 SKIP_ENV_VALIDATION=true next build",
    "start": "next start",
    "lint": "eslint",
    "build:exe": "npm run build && pkg . --config pkg.config.json",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development next dev\" \"wait-on http://localhost:3001 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run electron:clean && cross-env NEXT_TELEMETRY_DISABLED=1 npm run build && npm run electron:compile && node -e \"const fs=require('fs'); if(!fs.existsSync('electron/main.js')||!fs.existsSync('electron/preload.js')){console.error('Compiled files not found!'); process.exit(1);}\" && electron-builder --win",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:pack": "npm run build && npm run electron:compile && electron-builder --dir",
    "electron:clean": "node scripts/clean-dist.js || (powershell -Command \"if (Test-Path dist) { Rename-Item -Path dist -NewName ('dist.old.' + (Get-Date -Format 'yyyyMMddHHmmss')) -Force -ErrorAction SilentlyContinue }\" && echo \"Папка dist переименована\")"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.559.0",
    "next": "16.0.8",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/electron": "^1.4.38",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "pkg": "^5.8.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.timetable.frontend",
    "productName": "Timetable",
    "directories": {
      "output": "dist-build"
    },
    "forceCodeSigning": false,
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
