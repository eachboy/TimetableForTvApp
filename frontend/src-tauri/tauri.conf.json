{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Timetable",
  "version": "0.1.0",
  "identifier": "com.eachboy.Timetable",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Timetable",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/backend"]
  }
}