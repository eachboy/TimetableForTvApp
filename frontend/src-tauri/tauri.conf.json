{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Timetable",
  "version": "1.1.0",
  "identifier": "com.eachboy.Timetable",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Timetable",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/backend"],
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "linux": {
      "appimage": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_TAURI_SIGNING_PUBLIC_KEY",
      "endpoints": [
        "http://timetable-admin.local:9000/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}